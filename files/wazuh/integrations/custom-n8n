#!/usr/bin/env python3
"""
Wazuh custom integration: forward alerts to n8n webhook.

This script is called by the Wazuh manager's integratord daemon
whenever an alert matches the <integration> criteria in ossec.conf.

Arguments:
  $1 = alert JSON file path
  $2 = (unused) API key
  $3 = hook_url
"""

import json
import sys

try:
    from urllib2 import Request, urlopen, HTTPError  # Python 2
except ImportError:
    from urllib.request import Request, urlopen  # Python 3
    from urllib.error import HTTPError


def main():
    if len(sys.argv) < 4:
        sys.exit(1)

    alert_file = sys.argv[1]
    hook_url = sys.argv[3]

    with open(alert_file) as f:
        alert = json.load(f)

    data = json.dumps(alert).encode("utf-8")
    request = Request(hook_url, data=data)
    request.add_header("Content-Type", "application/json")

    try:
        urlopen(request)
    except HTTPError as e:
        # Log but don't crash — integratord will retry
        sys.stderr.write("custom-n8n: HTTP {}: {}\n".format(e.code, e.read().decode()))
        sys.exit(1)
    except Exception as e:
        sys.stderr.write("custom-n8n: {}\n".format(str(e)))
        sys.exit(1)


if __name__ == "__main__":
    main()
